# ─── Nodemailer / SMTP ────────────────────────────────────────────────────────
#
# Copy this file to .env.local and fill in the real values.
# .env.local is already in .gitignore — never commit real credentials.
#
# ── Gmail (recommended) ───────────────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account.
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail" → copy the 16-char code below.
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# The address that receives contact-form submissions (your inbox)
CONTACT_TO="example@gmail.com"

# ── Other providers (uncomment whichever you prefer) ──────────────────────────
# Outlook / Hotmail
# SMTP_HOST=smtp.live.com
# SMTP_PORT=587
# SMTP_USER=you@outlook.com
# SMTP_PASS=your-password

# SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxx
